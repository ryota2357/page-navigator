{
  "name": "page-navigator",
  "description": "Keybinding-based page-navigation browser extension for Chrome and Firefox.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "format": "biome format --write ./",
    "check": "biome check ./",
    "check:write": "biome check --write ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "fixtures": "node scripts/fixtures.ts",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@tsconfig/svelte": "5.0.8",
    "@types/sortablejs": "1.15.9",
    "@wxt-dev/module-svelte": "2.0.5",
    "happy-dom": "20.10.6",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-svelte-plugin": "0.3.52",
    "vitest": "4.1.9",
    "wxt": "0.20.26"
  },
  "dependencies": {
    "@core/unknownutil": "jsr:4.4.0-pre.1",
    "@lucide/svelte": "1.16.0",
    "@webext-core/messaging": "3.0.1",
    "sortablejs": "1.15.7"
  }
}
